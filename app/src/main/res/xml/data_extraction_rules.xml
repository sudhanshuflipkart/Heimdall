<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) data extraction rules for Heimdall.
    Controls what is included/excluded in cloud backups and device-to-device transfers.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="heimdall_settings.xml" />
        <exclude domain="cache" path="osmdroid" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="heimdall_settings.xml" />
        <exclude domain="cache" path="osmdroid" />
    </device-transfer>
</data-extraction-rules>
